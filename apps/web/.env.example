# Browser clients default to same-origin `/api` (App Router proxy → Nest API).
# Leave unset or set NEXT_PUBLIC_API_URL=/api for Cloudflare Workers.
NEXT_PUBLIC_API_URL=/api

# Local full-stack without the /api proxy (optional):
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side / Worker secret — upstream Nest API (Render in production).
# Set via Cloudflare dashboard / wrangler secret; do not commit real URLs with credentials.
# API_INTERNAL_URL=http://localhost:3001
# API_INTERNAL_URL=https://<your-render-api-host>

# Never set DATABASE_URL on the Cloudflare Worker.
