{
  "name": "@nelna/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "prebuild": "node ../../scripts/release/generate-release-manifest.js --service=fgdetails",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "preview": "node ../../scripts/release/generate-release-manifest.js --service=fgdetails && opennextjs-cloudflare build && wrangler dev",
    "deploy": "node ../../scripts/release/generate-release-manifest.js --service=fgdetails --environment=production && opennextjs-cloudflare build && node ../../scripts/release/wrangler-deploy-with-sha.js",
    "upload": "node ../../scripts/release/generate-release-manifest.js --service=fgdetails && opennextjs-cloudflare build && wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@nelna/shared": "workspace:*",
    "@nelna/ui": "workspace:*",
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.2",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9",
    "wrangler": "^4.110.0"
  }
}
