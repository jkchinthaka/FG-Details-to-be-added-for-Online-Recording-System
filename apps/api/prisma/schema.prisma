// Node 24 fix: the default two-package output (`.prisma/client` + `@prisma/client`)
// relies on a private `#main-entry-point` subpath import that fails to resolve when
// nested inside pnpm's content-addressable store (ERR_PACKAGE_IMPORT_NOT_DEFINED).
// Generating into a single self-contained folder and importing it directly avoids
// that broken resolution path entirely while keeping the classic (non-driver-adapter)
// Prisma Client API. See docs/DATABASE_DESIGN.md for details.
generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma-client"
  engineType = "library"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_ACTIVATION
}

/**
 * Lifecycle of an operational record. Verified records are never physically deleted.
 */
enum RecordStatus {
  DRAFT
  SUBMITTED
  PENDING_CHECK
  CHECKED
  PENDING_VERIFICATION
  VERIFIED
  COMPLETED
  RETURNED_FOR_CORRECTION
  RESUBMITTED
  REJECTED
  ARCHIVED
}

/**
 * Unified result vocabulary shared by cleaning checklists (Acceptable/Unacceptable/N/A)
 * and truck checklists (Pass/Fail/N/A). A single enum keeps InspectionResult generic
 * across checklist template types; each ChecklistItem only ever surfaces the subset
 * relevant to its template in the UI/seed layer.
 */
enum ResultStatus {
  ACCEPTABLE
  UNACCEPTABLE
  NOT_APPLICABLE
  PASS
  FAIL
}

enum ApprovalType {
  CHECK
  VERIFY
  RETURN
  REJECT
  VOID
  AMEND
  LOADING_DECISION
  CORRECTIVE_ACTION_VERIFICATION
  TEMPLATE_PUBLISH
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
}

enum CorrectiveActionStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  PENDING_VERIFICATION
  REJECTED
  VERIFIED
  CLOSED
  REOPENED
  OVERDUE
  CANCELLED
  CANCELLED_WITH_REASON
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

/**
 * Final freezer-truck-before-loading decision vocabulary (NMS/PPU/CL/30).
 * `PENDING` is the only state before an operator has submitted the
 * inspection; `APPROVED_FOR_LOADING`/`CONDITIONALLY_APPROVED` are the two
 * "may load" outcomes, `LOADING_BLOCKED` is the automatic, non-overridable
 * outcome of a critical failure, and `REJECTED` is a supervisor/QA decision
 * that the truck must not be used at all. See docs/records.md.
 */
enum LoadingDecisionStatus {
  PENDING
  APPROVED_FOR_LOADING
  CONDITIONALLY_APPROVED
  LOADING_BLOCKED
  REJECTED
}

/**
 * A ChecklistTemplate always has exactly one template overall; each
 * ChecklistTemplateVersion carries its own status so published versions stay
 * historically stable once records reference them.
 */
enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttachmentKind {
  EVIDENCE
  CORRECTIVE_ACTION
  GENERAL
}

/**
 * Response type a ChecklistItem collects. Drives which control the dynamic
 * checklist renderer shows and which validation rules are meaningful for
 * the item (see docs/CHECKLIST_ENGINE.md).
 */
enum ChecklistItemType {
  PASS_FAIL_NA
  ACCEPTABLE_UNACCEPTABLE_NA
  YES_NO_NA
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  TEMPERATURE
  DATE
  TIME
  SINGLE_SELECT
  PHOTO_EVIDENCE
  SIGNATURE
}

enum NotificationType {
  TASK_ASSIGNED
  RECORD_REJECTED
  RECORD_VERIFIED
  RECORD_RETURNED
  RECORD_CHECKED
  RECORD_PENDING_VERIFICATION
  CORRECTIVE_ACTION_ASSIGNED
  CORRECTIVE_ACTION_DUE
  SYSTEM
}

/**
 * Mirrors the shared `TaskStatus` union (packages/shared/src/records.ts) so
 * the "Today's Tasks" dashboard can read a TaskAssignment's status straight
 * through without a translation layer.
 */
enum TaskAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  employeeCode String     @unique
  username     String?    @unique
  fullName     String
  email        String?    @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  mustChangePassword Boolean  @default(true)
  passwordChangedAt  DateTime?
  deactivatedAt      DateTime?
  /** Incremented on password/role/security changes; embedded in JWT for immediate invalidation. */
  authVersion        Int       @default(0)

  /**
   * Failed-login protection: an attempt counter with a timed lockout.
   * Reset to 0 / null on every successful password verification.
   * See docs/AUTHENTICATION.md for the exact policy.
   */
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?

  departmentId String?    @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sectionId    String?    @db.ObjectId
  section      Section?   @relation(fields: [sectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  userRoles                  UserRole[]
  refreshTokens              RefreshToken[]
  createdRecords             InspectionRecord[]         @relation("RecordCreatedBy")
  checkedRecords             InspectionRecord[]         @relation("RecordCheckedBy")
  verifiedRecords            InspectionRecord[]         @relation("RecordVerifiedBy")
  uploadedAttachments        InspectionAttachment[]
  decidedApprovals           ApprovalRecord[]           @relation("ApprovalDecidedBy")
  createdCorrectiveActions   CorrectiveAction[]         @relation("CorrectiveActionCreatedBy")
  assignedCorrectiveActions  CorrectiveAction[]         @relation("CorrectiveActionAssignee")
  verifiedCorrectiveActions  CorrectiveAction[]         @relation("CorrectiveActionVerifiedBy")
  closedCorrectiveActions    CorrectiveAction[]         @relation("CorrectiveActionClosedBy")
  uploadedCorrectiveEvidence CorrectiveActionEvidence[]
  publishedTemplateVersions  ChecklistTemplateVersion[] @relation("TemplateVersionPublishedBy")
  createdTemplates           ChecklistTemplate[]        @relation("TemplateCreatedBy")
  decidedTruckLoadings       TruckInspectionDetail[]    @relation("TruckLoadingDecidedBy")
  notifications              Notification[]
  auditLogs                  AuditLog[]
  taskAssignments            TaskAssignment[]

  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roleId     String   @db.ObjectId
  role       Role     @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permissionId String     @db.ObjectId
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/**
 * Refresh-token backed sessions (JWT access token + rotating refresh token).
 */
model RefreshToken {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  userId            String    @db.ObjectId
  user              User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tokenHash         String    @unique
  issuedAt          DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?   @db.ObjectId
  userAgent         String?
  ipAddress         String?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

model Department {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections Section[]
  users    User[]

  @@map("departments")
}

model Section {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  departmentId String     @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name         String
  code         String     @unique
  description  String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  users   User[]
  records InspectionRecord[]

  @@unique([departmentId, name])
  @@map("sections")
}

model Shift {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  code      String   @unique
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records         InspectionRecord[]
  taskAssignments TaskAssignment[]

  @@map("shifts")
}

// ---------------------------------------------------------------------------
// Checklist management (versioned)
// ---------------------------------------------------------------------------

/**
 * The stable, addressable checklist definition (e.g. NMS/PPU/CL/24). Individual
 * versions carry the actual sections/items; the template groups them and tracks
 * which version is currently published.
 */
model ChecklistTemplate {
  id               String                    @id @default(auto()) @map("_id") @db.ObjectId
  code             String                    @unique
  title            String
  description      String?
  isActive         Boolean                   @default(true)
  // @unique required for Prisma 1-1; MongoDB non-sparse unique rejects multiple
  // nulls. Production must NOT use prisma db push for this — use
  // db:indexes:sync / ensure-sparse-current-version-index.js (partial unique).
  // Local/dev only: prisma:push then ensure-sparse-current-version-index.js.
  currentVersionId String?                   @unique @db.ObjectId
  currentVersion   ChecklistTemplateVersion? @relation("TemplateCurrentVersion", fields: [currentVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById      String?                   @db.ObjectId
  createdBy        User?                     @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  versions ChecklistTemplateVersion[] @relation("TemplateVersions")

  @@map("checklist_templates")
}

/**
 * Immutable once published: InspectionRecord always references the exact version
 * it was recorded against so historical records remain interpretable even after
 * the template evolves.
 */
model ChecklistTemplateVersion {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  templateId    String            @db.ObjectId
  template      ChecklistTemplate @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versionNumber Int
  status        TemplateStatus    @default(DRAFT)
  notes         String?
  publishedById String?           @db.ObjectId
  publishedBy   User?             @relation("TemplateVersionPublishedBy", fields: [publishedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  sections           ChecklistSection[]
  inspectionRecords  InspectionRecord[]
  currentForTemplate ChecklistTemplate? @relation("TemplateCurrentVersion")

  @@unique([templateId, versionNumber])
  @@index([templateId, status])
  @@map("checklist_template_versions")
}

model ChecklistSection {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  templateVersionId String                   @db.ObjectId
  templateVersion   ChecklistTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  name              String
  sortOrder         Int
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  items ChecklistItem[]

  @@unique([templateVersionId, sortOrder])
  @@map("checklist_sections")
}

model ChecklistItem {
  id         String            @id @default(auto()) @map("_id") @db.ObjectId
  sectionId  String            @db.ObjectId
  section    ChecklistSection  @relation(fields: [sectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  label      String
  helpText   String?
  sortOrder  Int
  itemType   ChecklistItemType @default(ACCEPTABLE_UNACCEPTABLE_NA)
  isRequired Boolean           @default(true)

  /**
   * Configurable validation/behaviour rules (see docs/CHECKLIST_ENGINE.md):
   * - allowNotApplicable: item may be answered N/A.
   * - requiresEvidenceOnFail: a photo is required when the response is a failure.
   * - isCriticalFailure: a failing response on this item marks the whole
   * record as a critical failure (surfaced prominently, blocks low-click
   * "mark all acceptable" from silently covering it).
   * - remarkRequiredOnFail / correctiveActionRequiredOnFail: extra text is
   * mandatory once a failing response is recorded.
   * - minValue/maxValue: inclusive numeric bounds for NUMBER/TEMPERATURE items.
   * - defaultResponse: pre-filled value (e.g. a default PASS) an operator can
   * still override; never auto-applied over an existing manual answer.
   */
  allowNotApplicable             Boolean @default(false)
  requiresEvidenceOnFail         Boolean @default(false)
  isCriticalFailure              Boolean @default(false)
  remarkRequiredOnFail           Boolean @default(false)
  correctiveActionRequiredOnFail Boolean @default(false)
  minValue                       Float?
  maxValue                       Float?
  defaultResponse                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options           ChecklistItemOption[]
  inspectionResults InspectionResult[]

  @@unique([sectionId, sortOrder])
  @@map("checklist_items")
}

/**
 * Optional preset reason/option list attached to a checklist item, e.g. a
 * dropdown of standard failure reasons. Not required for the basic
 * Acceptable/Unacceptable/N/A flow.
 */
model ChecklistItemOption {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  itemId    String        @db.ObjectId
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  value     String
  label     String
  sortOrder Int           @default(0)

  @@unique([itemId, value])
  @@map("checklist_item_options")
}

// ---------------------------------------------------------------------------
// Operational records
// ---------------------------------------------------------------------------

/**
 * One completed (or in-progress) checklist submission against an exact
 * ChecklistTemplateVersion. Soft lifecycle only — verified records are never
 * physically deleted; use `status = ARCHIVED` and `archivedAt`.
 */
model InspectionRecord {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  templateVersionId String                   @db.ObjectId
  templateVersion   ChecklistTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documentCode      String
  status            RecordStatus             @default(DRAFT)
  recordDate        DateTime
  shiftId           String?                  @db.ObjectId
  shift             Shift?                   @relation(fields: [shiftId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sectionId         String?                  @db.ObjectId
  section           Section?                 @relation(fields: [sectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  areaLabel         String?

  createdById  String  @db.ObjectId
  createdBy    User    @relation("RecordCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checkedById  String? @db.ObjectId
  checkedBy    User?   @relation("RecordCheckedBy", fields: [checkedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verifiedById String? @db.ObjectId
  verifiedBy   User?   @relation("RecordVerifiedBy", fields: [verifiedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  /**
   * When this record is a re-inspection (e.g. after a freezer truck was
   * temporarily blocked from loading and corrective action was taken),
   * points back at the original record so the two stay traceably linked —
   * see the "re-inspection creates traceable history" business rule.
   */
  reinspectionOfId String?            @db.ObjectId
  reinspectionOf   InspectionRecord?  @relation("RecordReinspection", fields: [reinspectionOfId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reinspections    InspectionRecord[] @relation("RecordReinspection")

  submittedAt DateTime?
  checkedAt   DateTime?
  verifiedAt  DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results           InspectionResult[]
  attachments       InspectionAttachment[]
  approvals         ApprovalRecord[]
  correctiveActions CorrectiveAction[]
  truckDetail       TruckInspectionDetail?
  taskAssignments   TaskAssignment[]

  @@index([documentCode, recordDate])
  @@index([status])
  @@index([templateVersionId])
  @@index([reinspectionOfId])
  @@map("inspection_records")
}

/**
 * A checklist template assigned to a specific user for a specific day/shift
 * — the backing data for the mobile "Today's Tasks" dashboard (see
 * docs/records.md). Deliberately keyed by `templateCode` rather than a
 * ChecklistTemplate relation: assignments are generated ahead of a
 * template's published version potentially changing, and the code alone is
 * enough to route to the right mobile form (see @nelna/shared RECORD_TYPE_META).
 *
 * `recordId` is populated once the operator starts/submits the actual
 * InspectionRecord, letting the dashboard reflect live record status without
 * duplicating it — see docs/CHECKLIST_ENGINE.md for the record submission
 * flow this links up to in a later phase.
 */
model TaskAssignment {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  assignedToId String               @db.ObjectId
  assignedTo   User                 @relation(fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templateCode String
  areaLabel    String
  shiftId      String?              @db.ObjectId
  shift        Shift?               @relation(fields: [shiftId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dueDate      DateTime
  status       TaskAssignmentStatus @default(ASSIGNED)
  recordId     String?              @db.ObjectId
  record       InspectionRecord?    @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Idempotent-seeding key: at most one assignment per user/template/day.
  // recordId uniqueness when linked is enforced in application code (Mongo null unique limitation).
  @@unique([assignedToId, templateCode, dueDate])
  @@index([assignedToId, dueDate])
  @@index([recordId])
  @@map("task_assignments")
}

model InspectionResult {
  id       String           @id @default(auto()) @map("_id") @db.ObjectId
  recordId String           @db.ObjectId
  record   InspectionRecord @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  itemId   String           @db.ObjectId
  item     ChecklistItem    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status   ResultStatus

  /**
   * Why the item failed. Required at the application layer when status is
   * UNACCEPTABLE/FAIL.
   */
  issueReason      String?
  correction       String?
  correctiveAction String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments       InspectionAttachment[]
  correctiveActions CorrectiveAction[]

  @@unique([recordId, itemId])
  @@index([itemId, status])
  @@map("inspection_results")
}

model InspectionAttachment {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  recordId           String            @db.ObjectId
  record             InspectionRecord  @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resultId           String?           @db.ObjectId
  result             InspectionResult? @relation(fields: [resultId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  kind               AttachmentKind    @default(EVIDENCE)
  /// Legacy / derived download path — binary lives in GridFS when gridFsFileId is set
  fileUrl            String
  fileName           String
  storedFileName     String?
  mimeType           String
  sizeBytes          Int
  contentSha256      String?
  gridFsFileId       String?
  gridFsBucket       String?           @default("fgEvidence")
  retentionStatus    String            @default("ACTIVE")
  uploadCorrelationId String?
  uploadedById       String            @db.ObjectId
  uploadedBy         User              @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  uploadedAt         DateTime          @default(now())

  @@index([recordId])
  @@index([resultId])
  @@index([gridFsFileId])
  @@map("inspection_attachments")
}

// ---------------------------------------------------------------------------
// Truck
// ---------------------------------------------------------------------------

model Transporter {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  contactPhone String?
  contactEmail String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicles         Vehicle[]
  drivers          Driver[]
  truckInspections TruckInspectionDetail[]

  @@map("transporters")
}

model Vehicle {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  vehicleNumber      String        @unique
  freezerTruckNumber String?       @unique
  /** Optional QR code identifier printed/affixed to the vehicle for
   *  quick lookup at the loading bay — admin-assigned, not auto-generated. */
  qrIdentifier       String?       @unique
  status             VehicleStatus @default(ACTIVE)
  transporterId      String?       @db.ObjectId
  transporter        Transporter?  @relation(fields: [transporterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  inspections TruckInspectionDetail[]

  @@map("vehicles")
}

model Driver {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  fullName      String
  licenseNumber String       @unique
  phone         String?
  isActive      Boolean      @default(true)
  transporterId String?      @db.ObjectId
  transporter   Transporter? @relation(fields: [transporterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  inspections TruckInspectionDetail[]

  @@map("drivers")
}

/**
 * One-to-one extension of InspectionRecord for freezer-truck-before-loading
 * inspections (NMS/PPU/CL/30) carrying truck/driver identifiers and the
 * final loading decision.
 */
model TruckInspectionDetail {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  recordId           String           @unique @db.ObjectId
  record             InspectionRecord @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicleId          String?          @db.ObjectId
  vehicle            Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driverId           String?          @db.ObjectId
  driver             Driver?          @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transporterId      String?          @db.ObjectId
  transporter        Transporter?     @relation(fields: [transporterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  freezerTruckNumber String
  vehicleNumber      String
  /** Paper form “Time” for NMS/PPU/CL/30 — HH:mm in Asia/Colombo, set at
   *  draft creation (auto-captured, not free-typed by the operator). */
  inspectionTime String?
  /** Free-text loading/dispatch reference (e.g. a delivery order/loading
   *  plan number) and the product category being loaded, when applicable —
   *  both optional since not every inspection is tied to a specific load. */
  loadingReference String?
  productCategory  String?

  /** Reserved structure for a future temperature-logging phase — current
   *  reading plus the acceptable min/max band and a computed acceptability
   *  flag. Entirely optional; no current checklist item requires it. */
  temperatureCurrent    Float?
  temperatureMin        Float?
  temperatureMax        Float?
  temperatureAcceptable Boolean?

  /** System-computed recommendation from `computeRecommendedLoadingDecision`
   *  at operator-submit time — never overwritten afterwards, so the
   *  original recommendation (and whether it reflected a critical failure)
   *  stays visible even after a supervisor/QA records the final decision. */
  recommendedDecision LoadingDecisionStatus?
  /** The current/final decision. Starts as the operator's recommendation on
   *  submit and can only be changed via the role-gated approval endpoint —
   *  a critical-failure recommendation (`LOADING_BLOCKED`) can never be
   *  overridden to an "approved" outcome. */
  loadingDecision LoadingDecisionStatus @default(PENDING)
  decidedById     String?               @db.ObjectId
  decidedBy       User?                 @relation("TruckLoadingDecidedBy", fields: [decidedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  decidedAt       DateTime?
  remarks         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("truck_inspection_details")
}

// ---------------------------------------------------------------------------
// Workflow
// ---------------------------------------------------------------------------

model ApprovalRecord {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  recordId     String           @db.ObjectId
  record       InspectionRecord @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvalType ApprovalType
  decision     ApprovalDecision @default(PENDING)
  decidedById  String?          @db.ObjectId
  decidedBy    User?            @relation("ApprovalDecidedBy", fields: [decidedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  decidedAt    DateTime?
  comments     String?
  createdAt    DateTime         @default(now())

  @@index([recordId, approvalType])
  @@map("approval_records")
}

model CorrectiveAction {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  recordId    String?                @db.ObjectId
  record      InspectionRecord?      @relation(fields: [recordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resultId    String?                @db.ObjectId
  result      InspectionResult?      @relation(fields: [resultId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  actionNumber String?               @unique
  title       String
  description String
  status      CorrectiveActionStatus @default(OPEN)
  priority    Priority               @default(MEDIUM)

  rootCause             String?
  immediateCorrection   String?
  completionComment     String?
  verificationComment   String?
  rejectionReason       String?
  cancelReason          String?

  createdById  String  @db.ObjectId
  createdBy    User    @relation("CorrectiveActionCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedToId String? @db.ObjectId
  assignedTo   User?   @relation("CorrectiveActionAssignee", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verifiedById String? @db.ObjectId
  verifiedBy   User?   @relation("CorrectiveActionVerifiedBy", fields: [verifiedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  closedById   String? @db.ObjectId
  closedBy     User?   @relation("CorrectiveActionClosedBy", fields: [closedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  dueDate     DateTime?
  completedAt DateTime?
  verifiedAt  DateTime?
  closedAt    DateTime?
  reopenedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidence CorrectiveActionEvidence[]

  // At-most-one CA per result is enforced in application code (Mongo null unique limitation).
  @@index([resultId])
  @@index([status, priority])
  @@index([assignedToId, status])
  @@index([dueDate, status])
  @@map("corrective_actions")
}

model CorrectiveActionEvidence {
  id                  String           @id @default(auto()) @map("_id") @db.ObjectId
  correctiveActionId  String           @db.ObjectId
  correctiveAction    CorrectiveAction @relation(fields: [correctiveActionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fileUrl             String
  fileName            String
  storedFileName      String?
  mimeType            String
  sizeBytes           Int
  contentSha256       String?
  gridFsFileId        String?
  gridFsBucket        String?          @default("fgEvidence")
  retentionStatus     String           @default("ACTIVE")
  uploadCorrelationId String?
  notes               String?
  uploadedById        String           @db.ObjectId
  uploadedBy          User             @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  uploadedAt          DateTime         @default(now())

  @@index([correctiveActionId])
  @@index([gridFsFileId])
  @@map("corrective_action_evidence")
}

// ---------------------------------------------------------------------------
// Admin master data (Prompt 32)
//
// All master-data rows are soft-lifecycle only (`isActive`) — the admin APIs
// never physically delete a row that may already be referenced historically
// (see docs/DATABASE_DESIGN.md "no hard-delete of masters" principle).
// ---------------------------------------------------------------------------

model FailureReason {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  code      String   @unique
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("failure_reasons")
}

model CorrectiveActionCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("corrective_action_categories")
}

model TemperatureProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  code       String   @unique
  name       String
  minCelsius Float
  maxCelsius Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("temperature_profiles")
}

/**
 * Admin-managed key/value store for approved loading-decision policy
 * configuration (e.g. which checklist items block loading, escalation
 * rules). The API only stores/returns whatever `config` an admin posts —
 * it never invents or hard-codes Nelna's actual policy content (see
 * docs/requirements/OPEN_BUSINESS_DECISIONS.md).
 */
model LoadingDecisionPolicy {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  description String?
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("loading_decision_policies")
}

// ---------------------------------------------------------------------------
// System
// ---------------------------------------------------------------------------

model Notification {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  userId            String           @db.ObjectId
  user              User             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type              NotificationType
  title             String
  body              String
  isRead            Boolean          @default(false)
  readAt            DateTime?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId    String?  @db.ObjectId
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
