generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FG_OPERATOR
  FG_SUPERVISOR
  QA_EXECUTIVE
  FOOD_SAFETY_TEAM_LEADER
  SYSTEM_ADMINISTRATOR
  AUDITOR
}

enum WorkShift {
  MORNING
  AFTERNOON
  NIGHT
}

enum RecordType {
  DAILY_CLEANING_VERIFICATION
  FREEZER_TRUCK_INSPECTION
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  VERIFIED
  REJECTED
}

enum CheckItemResult {
  ACCEPTABLE
  FAIL
}

enum LoadingDecision {
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  employeeCode String   @unique
  fullName     String
  email        String?  @unique
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks     TaskAssignment[] @relation("TaskAssignee")
  checkedRecords    FgRecord[]       @relation("RecordCheckedBy")
  verifiedRecords   FgRecord[]       @relation("RecordVerifiedBy")
  auditLogs         AuditLog[]
}

model Vehicle {
  id                String   @id @default(cuid())
  freezerTruckNumber String  @unique
  vehicleNumber     String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inspections FreezerTruckInspection[]
}

model TaskAssignment {
  id          String     @id @default(cuid())
  recordType  RecordType
  status      TaskStatus @default(ASSIGNED)
  shift       WorkShift
  workDate    DateTime   @db.Date
  areaLabel   String
  assigneeId  String
  assignee    User       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  recordId    String?    @unique
  record      FgRecord?  @relation(fields: [recordId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workDate, assigneeId, status])
}

model FgRecord {
  id           String     @id @default(cuid())
  recordType   RecordType
  documentCode String
  shift        WorkShift
  recordedAt   DateTime
  status       TaskStatus @default(SUBMITTED)
  checkedById  String?
  checkedBy    User?      @relation("RecordCheckedBy", fields: [checkedById], references: [id])
  verifiedById String?
  verifiedBy   User?      @relation("RecordVerifiedBy", fields: [verifiedById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  task                     TaskAssignment?
  cleaningVerification     DailyCleaningVerification?
  freezerTruckInspection   FreezerTruckInspection?
}

model DailyCleaningVerification {
  id       String   @id @default(cuid())
  recordId String   @unique
  record   FgRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  lines    CleaningCheckLine[]
}

model CleaningCheckLine {
  id               String                    @id @default(cuid())
  verificationId   String
  verification     DailyCleaningVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  itemId           String
  label            String
  area             String
  result           CheckItemResult
  failureNote      String?
  correctiveAction String?

  @@unique([verificationId, itemId])
}

model FreezerTruckInspection {
  id                 String           @id @default(cuid())
  recordId           String           @unique
  record             FgRecord         @relation(fields: [recordId], references: [id], onDelete: Cascade)
  vehicleId          String?
  vehicle            Vehicle?         @relation(fields: [vehicleId], references: [id])
  freezerTruckNumber String
  vehicleNumber      String
  correctiveAction   String?
  loadingDecision    LoadingDecision
  lines              FreezerTruckCheckLine[]
}

model FreezerTruckCheckLine {
  id           String                 @id @default(cuid())
  inspectionId String
  inspection   FreezerTruckInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  itemId       String
  label        String
  result       CheckItemResult
  failureNote  String?

  @@unique([inspectionId, itemId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
