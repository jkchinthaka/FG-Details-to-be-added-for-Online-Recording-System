{
  "name": "@nelna/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p prisma/tsconfig.json --noEmit",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:push": "prisma db push && node ../../scripts/database/ensure-sparse-current-version-index.js",
    "prisma:seed": "prisma db seed",
    "prisma:seed:production": "prisma db seed",
    "prisma:seed:demo": "node ./prisma/run-demo-seed.cjs",
    "prisma:studio": "prisma studio",
    "bootstrap:admin": "ts-node --transpile-only scripts/bootstrap-admin.ts",
    "users:migrate:dry-run": "ts-node --transpile-only scripts/archive-legacy-users.ts --dry-run",
    "users:migrate:execute": "ts-node --transpile-only scripts/archive-legacy-users.ts --execute",
    "prisma:migrate:legacy": "prisma migrate dev",
    "prisma:migrate:deploy:legacy": "prisma migrate deploy"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@nelna/shared": "workspace:*",
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@prisma/client": "^6.5.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "mongodb": "^7.5.0",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
