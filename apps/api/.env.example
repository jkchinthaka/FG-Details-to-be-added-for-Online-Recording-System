# Local development may still use PostgreSQL until the MongoDB migration branch merges.
# Production / Render MUST use MongoDB Atlas (see docs/deployment/MONGODB_ATLAS_SETUP.md):
# DATABASE_URL="mongodb+srv://<DB_USER>:<DB_PASSWORD>@cluster0.gsqzhij.mongodb.net/fg_online?retryWrites=true&w=majority&appName=Cluster0"
DATABASE_URL="postgresql://nelna:nelna@localhost:5432/nelna_fg?schema=public"
API_PORT=3001
# Render also injects PORT — main.ts listens on PORT ?? API_PORT ?? 3001
API_CORS_ORIGIN="http://localhost:3000"
NODE_ENV=development
# production | uat — production requires API_CORS_ORIGIN=https://fg.nelna.lk and DB fg_online
NELNA_DEPLOY_TIER=

# Released to /health (never put secrets here). Optional for local.
APP_VERSION=1.0.0
APP_BUILD_ID=
# When set, /health and /health/ready verify this path is readable/writable.
FILE_STORAGE_PATH=

# --- Auth (apps/api/src/auth) ---------------------------------------------
# JWT signing secrets. Required (and enforced) in production; falls back to
# clearly-labelled dev-only defaults locally. Never commit real secrets —
# generate your own with e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=dev-only-insecure-access-secret-change-me
JWT_REFRESH_SECRET=dev-only-insecure-refresh-secret-change-me

# Access token lifetime (short) and refresh token lifetime (long). Format:
# a number followed by ms|s|m|h|d, e.g. "15m", "7d".
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Set to "true" once served over HTTPS (required for SameSite cookies in
# production deploys). Must stay "false" for local http://localhost dev.
COOKIE_SECURE=false
# Production (fg.nelna.lk + fg-api.nelna.lk): COOKIE_DOMAIN=.nelna.lk and COOKIE_SECURE=true
# Leave unset for local http://localhost development.
COOKIE_DOMAIN=

# Failed-login protection: after this many consecutive wrong passwords the
# account is locked for LOGIN_LOCKOUT_MINUTES. See docs/AUTHENTICATION.md.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Seed users (apps/api/prisma/seed.ts) ---------------------------------
# Optional. Each sample account is only created when its EMAIL + PASSWORD
# pair below is set. Leave unset to skip creating that account (e.g. CI).
# Never commit real credentials — these are local/dev-only defaults.
# Passwords must be at least 8 characters; seed.ts hashes them with bcrypt.
SEED_ADMIN_EMPLOYEE_CODE=EMP-ADMIN-001
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=change-me-admin-pw
SEED_ADMIN_FULL_NAME="System Administrator"

SEED_OPERATOR_EMPLOYEE_CODE=EMP-OPERATOR-001
SEED_OPERATOR_EMAIL=operator@example.local
SEED_OPERATOR_PASSWORD=change-me-operator-pw
SEED_OPERATOR_FULL_NAME="FG Operator"

SEED_QA_EMPLOYEE_CODE=EMP-QA-001
SEED_QA_EMAIL=qa@example.local
SEED_QA_PASSWORD=change-me-qa-pw
SEED_QA_FULL_NAME="QA Executive"
