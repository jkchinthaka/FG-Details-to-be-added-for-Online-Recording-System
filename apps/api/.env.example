# NestJS API — environment template (never put real secrets here)

# MongoDB Atlas (required for runtime)
# Database MUST be fg_online in production; use fg_online_test for automated tests.
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.gsqzhij.mongodb.net/fg_online?retryWrites=true&w=majority&appName=Cluster0"

# Auth
JWT_ACCESS_SECRET="replace-with-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-long-random-refresh-secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# HTTP
API_PORT=3001
COOKIE_SECURE=false
# Leave COOKIE_DOMAIN empty for same-origin Cloudflare → /api → Render cookie mode
COOKIE_DOMAIN=
CORS_ORIGINS="http://localhost:3000"

# ---------------------------------------------------------------------------
# Seeding
# ---------------------------------------------------------------------------
# Default `pnpm --filter @nelna/api prisma:seed` (= prisma:seed:production) seeds
# ONLY reference configuration: roles, permissions, org, checklist templates.
#
# Demo operational data (sample users, fleet, tasks) requires:
#   ENABLE_DEMO_SEED=true
# and is REJECTED when NODE_ENV=production.
# Prefer: pnpm --filter @nelna/api prisma:seed:demo
#
# ENABLE_DEMO_SEED=true
# SEED_ADMIN_EMAIL=admin@example.local
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_EMPLOYEE_CODE=EMP-ADMIN-001
# SEED_OPERATOR_EMAIL=operator@example.local
# SEED_OPERATOR_PASSWORD=
# SEED_OPERATOR_EMPLOYEE_CODE=EMP-OPERATOR-001

# ---------------------------------------------------------------------------
# Sample cleanup bootstrap (optional)
# ---------------------------------------------------------------------------
# When creating the first production administrator (username login):
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_EMPLOYEE_CODE=
# BOOTSTRAP_ADMIN_FULL_NAME=
# BOOTSTRAP_ADMIN_EMAIL=
