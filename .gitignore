# Dependencies
node_modules/
.pnpm-store/

# Builds
dist/
build/
.next/
.open-next/
.wrangler/
out/
coverage/
*.tsbuildinfo

# Environment and secrets
.env
.env.local
.env.*.local
.dev.vars
!.env.example

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Logs and temp
*.log
npm-debug.log*
pnpm-debug.log*
tmp/
temp/
