.turbo/

# Prisma
apps/api/prisma/*.db
apps/api/prisma/*.db-journal
apps/api/generated/

# PWA generated
# Next.js / PWA generated artefacts (keep intentional `public/sw.js` tracked)
apps/web/public/workbox-*.js
apps/web/public/sw.js.map
# Note: apps/web/public/sw.js is the Prompt 34 service worker and is versioned.

# Cutover / ops reports (may contain operational metadata)
reports/
!reports/release/
!reports/release/**
# CI may write sanitized reports locally; do not commit them
reports/ci/

# Generated at build time; also written under reports/release/
apps/web/public/release-manifest.json

apps/e2e/playwright-report/
apps/e2e/test-results/
apps/e2e/junit-e2e.xml
